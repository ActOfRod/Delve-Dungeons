# ---------------------------------------------------------------------------
# Delve Dungeons environment configuration
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# AI Dungeon Master (optional)
# If no AI key is set, the app falls back to a built-in offline DM.
# Gemini is tried first when GOOGLE_GEMINI_API_KEY is set, then OpenAI.
# ---------------------------------------------------------------------------
GOOGLE_GEMINI_API_KEY=
# Use the exact model ID from AI Studio's dropdown (no spaces, lowercase).
# Newer accounts: gemini-3.1-flash-lite. Legacy: gemini-2.5-flash.
# Do NOT use gemini-2.0-flash or gemini-3.1-flash-lite-preview (shut down).
GOOGLE_GEMINI_MODEL=gemini-3.1-flash-lite
# Optional cap on response length (defaults: 1024, or 2048 for Gemini 3)
GOOGLE_GEMINI_MAX_OUTPUT_TOKENS=

# Gemini TTS for DM voice narration (uses same API key)
GOOGLE_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GOOGLE_GEMINI_TTS_VOICE=Charon

OPENAI_API_KEY=
# Model used for narration (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
