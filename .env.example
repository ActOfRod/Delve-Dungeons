# ---------------------------------------------------------------------------
# Delve Dungeons environment configuration
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# AI Dungeon Master (optional)
# If OPENAI_API_KEY is omitted, the app falls back to a built-in offline
# "DungeonMaster" that generates atmospheric narration locally.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
# Model used for narration (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
